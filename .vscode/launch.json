{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Client",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--disable-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/examples"
      ],
      "outFiles": [
        "${workspaceFolder}/clients/vscode/out/**/*.js"
      ],
      "preLaunchTask": "compile + bundle"
    },
    {
      "name": "Attach to Server",
      "type": "node",
      "request": "attach",
      "port": 6009,
      "restart": true,
      "outFiles": [
        "${workspaceFolder}/server/out/**/*.js"
      ]
    },
    {
      "name": "Debug MCP Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/server/mcpServer.mjs",
      "preLaunchTask": "compile + bundle",
      "console": "integratedTerminal",
      "outFiles": [
        "${workspaceFolder}/dist/server/mcpServer.mjs.map"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Client + Server",
      "configurations": [
        "Launch Client",
        "Attach to Server"
      ]
    }
  ]
}